<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head') %>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: var(--background);
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            overflow: hidden;
        }

        .splash {
            text-align: center;
            animation: fadeIn 0.8s ease;
            padding: 20px;
        }

        .logo-svg {
            width: 120px;
            height: 120px;
            margin-bottom: 16px;
        }

        .logo-svg line {
            stroke: #4c43e6;
            stroke-width: 10;
            stroke-linecap: round;
            fill: none;
            stroke-dasharray: 200;
            stroke-dashoffset: 200;
            animation: drawLine 1s ease forwards;
        }

        .logo-svg line:nth-child(1) { animation-delay: 0.2s; }
        .logo-svg line:nth-child(2) { animation-delay: 0.6s; }
        .logo-svg line:nth-child(3) { animation-delay: 1.0s; }

        .logo-svg circle {
            fill: #4c43e6;
            r: 0;
            animation: popCircle 0.5s ease forwards;
        }

        .logo-svg circle:nth-child(4) { animation-delay: 1.2s; }
        .logo-svg circle:nth-child(5) { animation-delay: 1.4s; }
        .logo-svg circle:nth-child(6) { animation-delay: 1.6s; }

        @keyframes drawLine {
            to { stroke-dashoffset: 0; }
        }

        @keyframes popCircle {
            0% { r: 0; opacity: 0; transform: scale(0); }
            60% { r: 14; opacity: 1; transform: scale(1.2); }
            100% { r: 12; transform: scale(1); opacity: 1; }
        }

        .splash .text {
            font-size: 52px;
            font-weight: 700;
            color: #4c43e6;
            letter-spacing: -2px;
            margin-top: 4px;
            opacity: 0;
            animation: textFade 0.8s ease 1.8s forwards;
        }

        .splash .sous-titre {
            font-size: 16px;
            color: var(--text-secondary);
            margin-top: 4px;
            font-weight: 400;
            opacity: 0;
            animation: textFade 0.8s ease 2.2s forwards;
        }

        .splash .message {
            margin-top: 24px;
            font-size: 18px;
            font-weight: 500;
            color: var(--text-primary);
            opacity: 0;
            animation: textFade 0.8s ease 2.6s forwards;
        }

        .splash .message i {
            color: #ef4444;
            margin-right: 6px;
        }

        .loader {
            margin-top: 32px;
            display: flex;
            justify-content: center;
            gap: 8px;
            opacity: 0;
            animation: textFade 0.6s ease 2.9s forwards;
        }

        .loader span {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: #4c43e6;
            animation: bounce 1.2s ease-in-out infinite;
        }

        .loader span:nth-child(2) { animation-delay: 0.2s; }
        .loader span:nth-child(3) { animation-delay: 0.4s; }

        .splash .version {
            margin-top: 32px;
            font-size: 12px;
            color: var(--text-muted);
            opacity: 0.4;
            opacity: 0;
            animation: textFade 0.6s ease 3.2s forwards;
        }

        .skip {
            position: fixed;
            top: 20px;
            right: 24px;
            font-size: 14px;
            color: #4c43e6;
            text-decoration: none;
            font-weight: 500;
            padding: 8px 16px;
            border-radius: 20px;
            background: rgba(76, 67, 230, 0.08);
            transition: background 0.2s;
            z-index: 10;
            opacity: 0;
            animation: textFade 0.6s ease 3.4s forwards;
        }

        .skip:hover {
            background: rgba(76, 67, 230, 0.15);
        }

        @keyframes fadeIn {
            0% { opacity: 0; transform: scale(0.96); }
            100% { opacity: 1; transform: scale(1); }
        }

        @keyframes textFade {
            0% { opacity: 0; transform: translateY(12px); }
            100% { opacity: 1; transform: translateY(0); }
        }

        @keyframes bounce {
            0%, 80%, 100% { transform: scale(0.6); opacity: 0.3; }
            40% { transform: scale(1); opacity: 1; }
        }

        @media (max-width: 480px) {
            .logo-svg { width: 90px; height: 90px; }
            .splash .text { font-size: 36px; }
            .splash .message { font-size: 15px; }
            .skip { font-size: 12px; padding: 6px 12px; }
        }
    </style>
</head>
<body>

    <a href="/login" class="skip" id="skipBtn">
        Passer <i class="fa-solid fa-arrow-right"></i>
    </a>

    <div class="splash">

        <!-- Logo animé -->
        <svg class="logo-svg" viewBox="0 0 100 100">
            <line x1="25" y1="55" x2="65" y2="25" />
            <line x1="65" y1="25" x2="75" y2="75" />
            <line x1="75" y1="75" x2="25" y2="55" />

            <circle cx="25" cy="55" />
            <circle cx="65" cy="25" />
            <circle cx="75" cy="75" />
        </svg>

        <div class="text">SocialApp</div>
        <div class="sous-titre">Connecte-toi à ta communauté</div>

        <div class="message">
            <i class="fa-solid fa-heart"></i>
            Bienvenue — retrouve tes amis en un clic
        </div>

        <div class="loader">
            <span></span>
            <span></span>
            <span></span>
        </div>

        <div class="version">v1.0 — SocialApp</div>
    </div>

    <script>
        setTimeout(() => {
            window.location.href = '/login';
        }, 3800);

        document.getElementById('skipBtn').addEventListener('click', (e) => {
            e.preventDefault();
            window.location.href = '/login';
        });

        document.addEventListener('click', (e) => {
            if (!e.target.closest('#skipBtn')) {
                window.location.href = '/login';
            }
        });
    </script>

</body>
</html>
