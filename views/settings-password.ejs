<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/navbar', { currentPage: 'profile' }) %>

    <div class="main-container">
        <%- include('partials/sidebar', { currentPage: 'profile' }) %>

        <main class="feed">
            <div class="page-header">
                <div>
                    <h1>Modifier le mot de passe</h1>
                    <div class="subtitle">Mets à jour ton mot de passe de connexion</div>
                </div>
                <a href="/profile/edit/me" class="btn btn-secondary" style="width:auto; padding:10px 20px;">
                    <i class="fa-solid fa-arrow-left"></i> Retour
                </a>
            </div>

            <% if (error && error.length > 0) { %>
                <div class="alert alert-error">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    <span><%= error[0] %></span>
                </div>
            <% } %>

            <% if (success && success.length > 0) { %>
                <div class="alert alert-success">
                    <i class="fa-solid fa-circle-check"></i>
                    <span><%= success[0] %></span>
                </div>
            <% } %>

            <div class="card">
                <div class="section-title" style="margin-bottom:20px;">
                    <i class="fa-solid fa-lock"></i>
                    Changer le mot de passe
                </div>

                <form action="/settings/password" method="POST">

                    <div class="form-group">
                        <label>Mot de passe actuel</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-lock"></i>
                            <input type="password" name="ancienMotDePasse" placeholder="Ton mot de passe actuel" required>
                        </div>
                    </div>

                    <div style="height:1px; background:var(--border); margin:20px 0;"></div>

                    <div class="form-group">
                        <label>Nouveau mot de passe</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-lock"></i>
                            <input type="password" name="motDePasse" id="newMdp" placeholder="Minimum 6 caractères" minlength="6" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Confirmer le nouveau mot de passe</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-lock"></i>
                            <input type="password" name="confirmMotDePasse" id="confirmMdp" placeholder="••••••••" minlength="6" required>
                        </div>
                        <div id="matchMsg" style="font-size:12px; margin-top:6px; display:none;"></div>
                    </div>

                    <div style="background:var(--primary-light); border-radius:var(--radius-sm); padding:12px 14px; margin-bottom:20px; font-size:13px; color:var(--text-secondary); line-height:1.5; display:flex; gap:10px; align-items:flex-start;">
                        <i class="fa-solid fa-circle-info" style="color:var(--primary); margin-top:2px; flex-shrink:0;"></i>
                        <span>Utilise un mot de passe unique que tu n'utilises pas ailleurs. Minimum 6 caractères.</span>
                    </div>

                    <button type="submit" class="btn">
                        <i class="fa-solid fa-check"></i>
                        Enregistrer le nouveau mot de passe
                    </button>
                </form>
            </div>
        </main>
    </div>

    <script>
        const newMdp = document.getElementById('newMdp')
        const confirmMdp = document.getElementById('confirmMdp')
        const matchMsg = document.getElementById('matchMsg')

        function checkMatch() {
            if (!confirmMdp.value) { matchMsg.style.display = 'none'; return }
            if (newMdp.value === confirmMdp.value) {
                matchMsg.style.display = 'block'
                matchMsg.innerHTML = '<i class="fa-solid fa-circle-check" style="color:#22c55e;"></i> <span style="color:#22c55e;">Les mots de passe correspondent</span>'
            } else {
                matchMsg.style.display = 'block'
                matchMsg.innerHTML = '<i class="fa-solid fa-circle-xmark" style="color:#ef4444;"></i> <span style="color:#ef4444;">Ne correspondent pas</span>'
            }
        }

        newMdp.addEventListener('input', checkMatch)
        confirmMdp.addEventListener('input', checkMatch)
    </script>
</body>
</html>
