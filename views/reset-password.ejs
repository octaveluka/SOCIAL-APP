<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <div class="auth-container">
        <div class="auth-visual">
            <div class="auth-visual-content">
                <i class="fa-solid fa-lock brand-icon"></i>
                <h2>Nouveau mot de passe</h2>
                <p>Identité vérifiée avec succès. Choisis un nouveau mot de passe sécurisé pour ton compte.</p>
                <div class="auth-visual-features">
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-circle-check" style="color:#22c55e;"></i>
                        <span>Identité confirmée — compte : <strong><%= email %></strong></span>
                    </div>
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-lock"></i>
                        <span>Minimum 6 caractères recommandés</span>
                    </div>
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>Choisis un mot de passe unique</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="auth-form-side">
            <div class="auth-card">
                <div class="auth-logo">
                    <i class="fa-solid fa-circle-nodes"></i>
                    <span>SocialApp</span>
                </div>

                <h2>Nouveau mot de passe</h2>
                <p class="auth-subtitle">Crée un mot de passe sécurisé</p>

                <% if (error && error.length > 0) { %>
                    <div class="alert alert-error">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span><%= error[0] %></span>
                    </div>
                <% } %>

                <% if (success && success.length > 0) { %>
                    <div class="alert alert-success">
                        <i class="fa-solid fa-circle-check"></i>
                        <span><%= success[0] %></span>
                    </div>
                <% } %>

                <form action="/reset-password" method="POST">
                    <div class="form-group">
                        <label>Nouveau mot de passe</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-lock"></i>
                            <input type="password" name="motDePasse" id="mdp" placeholder="Minimum 6 caractères" minlength="6" required autofocus>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Confirmer le mot de passe</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-lock"></i>
                            <input type="password" name="confirmMotDePasse" id="mdpConfirm" placeholder="••••••••" minlength="6" required>
                        </div>
                        <div id="matchMsg" style="font-size:12px; margin-top:5px; display:none;"></div>
                    </div>

                    <button type="submit" class="btn">
                        <i class="fa-solid fa-check"></i>
                        Enregistrer le nouveau mot de passe
                    </button>
                </form>

                <div class="auth-footer">
                    <a href="/login">Retour à la connexion</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        const mdp = document.getElementById('mdp')
        const mdpConfirm = document.getElementById('mdpConfirm')
        const matchMsg = document.getElementById('matchMsg')

        function checkMatch() {
            if (!mdpConfirm.value) { matchMsg.style.display = 'none'; return }
            if (mdp.value === mdpConfirm.value) {
                matchMsg.style.display = 'block'
                matchMsg.innerHTML = '<i class="fa-solid fa-circle-check" style="color:#22c55e;"></i> <span style="color:#22c55e;">Les mots de passe correspondent</span>'
            } else {
                matchMsg.style.display = 'block'
                matchMsg.innerHTML = '<i class="fa-solid fa-circle-xmark" style="color:#ef4444;"></i> <span style="color:#ef4444;">Ne correspondent pas</span>'
            }
        }

        mdp.addEventListener('input', checkMatch)
        mdpConfirm.addEventListener('input', checkMatch)
    </script>
</body>
</html>
