                                                </a>
                                                <div class="comment-right">
                                                    <div class="comment-bubble">
                                                        <div class="comment-author">
                                                            <a href="/profile/<%= reply.auteur._id %>" class="ajax-link" style="color:inherit;text-decoration:none;font-weight:inherit;"><%= reply.auteur.nom %></a>
                                                            <%- include('partials/badges', { badges: reply.auteur.badges || [] }) %>
                                                        </div>
                                                        <% if (reply.replyTo && reply.replyTo.nom) { %><span class="comment-reply-tag">↩ @<%= reply.replyTo.nom %></span><% } %>
                                                        <div class="comment-text"><%= reply.texte %></div>
                                                    </div>
                                                    <div class="comment-actions">
                                                        <button class="comment-like-btn <%= rUserReactionType ? 'liked' : '' %>"
                                                                data-post="<%= post._id %>"
                                                                data-comment="<%= reply._id %>"
                                                                data-reaction="<%= rUserReactionType || '' %>">
                                                            <% if (rUserReactionType) { %><span class="c-reaction-emoji"><%= CEMOJI[rUserReactionType] %></span><% } else { %><i class="fa-regular fa-heart"></i><% } %>
                                                            <% if (rTotalLikes > 0) { %><span class="comment-likes-count"><%= rTotalLikes %></span><% } %>
                                                        </button>
                                                        <button class="comment-reply-btn"
