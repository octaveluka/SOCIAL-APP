                                                                data-comment-id="<%= comment._id %>"
                                                                data-comment-author="<%= reply.auteur.nom %>"
                                                                data-comment-author-id="<%= reply.auteur._id %>">Répondre</button>
                                                    </div>
                                                </div>
                                            </div>
                                        <% }) %>
                                    </div>
                                <% } %>
                            <% }) %>
                        </div>
                        <div class="comment-form-wrap">
                            <div class="reply-indicator" style="display:none;">
                                <span>↩ <strong class="reply-to-name"></strong></span>
                                <button type="button" class="cancel-reply"><i class="fa-solid fa-xmark"></i></button>
                            </div>
                            <div class="mention-dropdown" style="display:none;"></div>
                            <form class="comment-form ajax-comment-form" data-id="<%= post._id %>">
                                <input type="text" name="texte" placeholder="Écrire un commentaire…" required autocomplete="off">
                                <button type="submit"><i class="fa-solid fa-paper-plane"></i></button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }) %>

