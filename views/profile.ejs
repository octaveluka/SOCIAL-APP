        const ALL_PICSUM_IDS = Array.from({length: 1084}, (_, i) => i + 1)
        let coverPage = 0
        const PAGE_SIZE = 60

        const COVER_TABS = [
            { id: 'tous',      label: '✨ Tous',          ids: null },
            { id: 'nature',    label: '🌿 Nature',         ids: NATURE_IDS },
            { id: 'villes',    label: '🏙️ Villes',         ids: VILLE_IDS },
            { id: 'mer',       label: '🌊 Mer',            ids: MER_IDS },
            { id: 'montagne',  label: '🏔️ Montagne',       ids: MONTAGNE_IDS },
            { id: 'animaux',   label: '🐾 Animaux',        ids: ANIMAL_IDS },
            { id: 'coucher',   label: '🌅 Coucher de soleil', ids: COUCHER_IDS },
            { id: 'abstract',  label: '🎨 Abstrait',       ids: ABSTRACT_IDS },
            { id: 'degrade',   label: '🎨 Dégradés',       ids: 'gradients' },
        ]

        let activeCoverTab = 'tous'

        function picsumThumb(id) { return `https://picsum.photos/id/${id}/320/120` }
        function picsumFull(id)  { return `https://picsum.photos/id/${id}/1200/450` }

        function coverItemHtml(value, isGradient) {
            const esc = value.replace(/"/g, '&quot;')
            if (isGradient) {
                return `<div class="cv-item" style="background:${value}" onclick="selectCover('${esc}',this,true)" title="${value}"></div>`
            }
            return `<div class="cv-item cv-photo" onclick="selectCover('${esc}',this,false)">
                        <img src="${value}" loading="lazy" alt="" onerror="this.closest('.cv-item').style.display='none'">
                    </div>`
        }

        function renderCoverTab(tabId) {
            activeCoverTab = tabId
            coverPage = 0
            const grid = document.getElementById('coverGrid')
            const loadMoreBtn = document.getElementById('coverLoadMore')
            const tab = COVER_TABS.find(t => t.id === tabId)

            document.querySelectorAll('.cv-tab').forEach(t => t.classList.toggle('active', t.dataset.tab === tabId))

            if (tab.ids === 'gradients') {
                grid.innerHTML = GRADIENT_PRESETS.map(g => coverItemHtml(g, true)).join('')
                loadMoreBtn.style.display = 'none'
                return
            }

            const ids = tab.ids || ALL_PICSUM_IDS
            const page = ids.slice(0, PAGE_SIZE)
            grid.innerHTML = page.map(id => coverItemHtml(picsumThumb(id), false)).join('')
            coverPage = 1
            loadMoreBtn.style.display = ids.length > PAGE_SIZE ? 'flex' : 'none'
            loadMoreBtn.dataset.source = tabId
        }

        function loadMoreCovers() {
            const tab = COVER_TABS.find(t => t.id === activeCoverTab)
            const ids = tab.ids || ALL_PICSUM_IDS
            const page = ids.slice(coverPage * PAGE_SIZE, (coverPage + 1) * PAGE_SIZE)
            if (!page.length) { document.getElementById('coverLoadMore').style.display = 'none'; return }
            const grid = document.getElementById('coverGrid')
            grid.insertAdjacentHTML('beforeend', page.map(id => coverItemHtml(picsumThumb(id), false)).join(''))
            coverPage++
            if ((coverPage) * PAGE_SIZE >= ids.length) document.getElementById('coverLoadMore').style.display = 'none'
        }

        async function selectCover(value, el, isGradient) {
            document.querySelectorAll('.cv-item').forEach(t => t.classList.remove('selected'))
            el.classList.add('selected')
            const coverUrl = isGradient ? value : picsumFull(value.match(/\/id\/(\d+)\//)?.[1] || 1)
            try {
                const res = await fetch('/api/profile/cover', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ coverUrl })
                })
                const data = await res.json()
                if (data.success) {
                    const bg = document.getElementById('profileCoverBg')
                    if (bg) {
                        if (isGradient) {
                            bg.style.backgroundImage = ''
                            bg.style.background = coverUrl
                        } else {
                            bg.style.background = ''
                            bg.style.backgroundImage = `url(${coverUrl})`
                            bg.style.backgroundSize = 'cover'
                            bg.style.backgroundPosition = 'center'
                        }
                        bg.style.backgroundColor = 'transparent'
                    }
                    setTimeout(() => closeCoverPicker(), 350)
                }
            } catch(e) {
                el.classList.remove('selected')
            }
        }

        function openCoverPicker() {
            const modal = document.getElementById('coverPickerModal')
            if (!modal) return
            modal.style.display = 'flex'
            document.body.style.overflow = 'hidden'
            if (!modal.dataset.built) {
                modal.dataset.built = '1'
                renderCoverTab('tous')
            }
        }

        function closeCoverPicker() {
            const modal = document.getElementById('coverPickerModal')
            if (modal) { modal.style.display = 'none'; document.body.style.overflow = '' }
        }

        document.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('coverPickerModal')
            if (modal) modal.addEventListener('click', e => { if (e.target === modal) closeCoverPicker() })
            document.addEventListener('keydown', e => { if (e.key === 'Escape') closeCoverPicker() })
        })
    </script>

    <!-- ═══════════════════════════════════════════════════
         COVER PICKER MODAL — 1400+ fonds
    ════════════════════════════════════════════════════ -->
    <% if (isOwnProfile) { %>
    <div id="coverPickerModal" style="
        display:none; position:fixed; inset:0; z-index:9999;
        background:rgba(0,0,0,0.65); backdrop-filter:blur(5px);
        align-items:center; justify-content:center; padding:16px;
    ">
        <div style="
            background:var(--card-bg); border-radius:20px;
            width:100%; max-width:780px; max-height:88vh;
            display:flex; flex-direction:column;
            box-shadow:0 32px 80px rgba(0,0,0,0.4);
            overflow:hidden;
            animation:cpIn .25s cubic-bezier(.34,1.56,.64,1) both;
        ">
            <!-- Header -->
            <div style="
                display:flex; align-items:center; justify-content:space-between;
                padding:20px 24px 14px; border-bottom:1px solid var(--border); flex-shrink:0;
            ">
                <div>
                    <div style="font-size:17px; font-weight:700; color:var(--text-primary);">
                        <i class="fa-solid fa-image" style="color:var(--primary); margin-right:8px;"></i>
                        Choisir un fond
                    </div>
                    <div style="font-size:13px; color:var(--text-muted); margin-top:2px;">
                        1 400+ fonds disponibles — clique pour appliquer
                    </div>
                </div>
                <button onclick="closeCoverPicker()" style="
                    background:var(--background); border:none; border-radius:50%;
                    width:36px; height:36px; cursor:pointer; font-size:16px;
                    color:var(--text-muted); display:flex; align-items:center; justify-content:center;
                    transition:background .15s;
                " onmouseover="this.style.background='var(--border)'" onmouseout="this.style.background='var(--background)'">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <!-- Tabs -->
            <div id="coverTabs" style="
                display:flex; gap:6px; padding:12px 24px;
                border-bottom:1px solid var(--border); flex-shrink:0;
                overflow-x:auto; scrollbar-width:none;
            ">
                <% const coverTabDefs = [
                    {id:'tous',     label:'✨ Tous'},
                    {id:'nature',   label:'🌿 Nature'},
                    {id:'villes',   label:'🏙️ Villes'},
                    {id:'mer',      label:'🌊 Mer'},
                    {id:'montagne', label:'🏔️ Montagne'},
                    {id:'animaux',  label:'🐾 Animaux'},
                    {id:'coucher',  label:'🌅 Coucher'},
                    {id:'abstract', label:'🎨 Abstrait'},
                    {id:'degrade',  label:'🌈 Dégradés'},
                ]; %>
                <% coverTabDefs.forEach(t => { %>
                <button class="cv-tab<%= t.id === 'tous' ? ' active' : '' %>"
                        data-tab="<%= t.id %>"
                        onclick="renderCoverTab('<%= t.id %>')"><%= t.label %></button>
                <% }) %>
            </div>

            <!-- Grid -->
            <div id="coverGrid" style="
                flex:1; min-height:0; overflow-y:auto; padding:16px 24px;
                display:grid;
                grid-template-columns:repeat(auto-fill, minmax(150px, 1fr));
                grid-auto-rows:64px;
                gap:10px;
                align-content:start;
                scrollbar-width:thin;
            ">
                <div style="grid-column:1/-1; text-align:center; padding:40px; color:var(--text-muted);">
                    <i class="fa-solid fa-spinner fa-spin" style="font-size:22px; display:block; margin-bottom:8px;"></i>
                    Chargement...
                </div>
            </div>

            <!-- Load more -->
            <div style="padding:12px 24px; border-top:1px solid var(--border); flex-shrink:0; display:flex; justify-content:center;">
                <button id="coverLoadMore" onclick="loadMoreCovers()" style="
                    display:none; align-items:center; gap:6px;
                    padding:9px 22px; border-radius:20px; font-size:13px; font-weight:600;
                    border:1.5px solid var(--border); background:var(--background);
                    color:var(--text-secondary); cursor:pointer; transition:all .15s;
                " onmouseover="this.style.borderColor='var(--primary)';this.style.color='var(--primary)'"
                   onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-secondary)'">
                    <i class="fa-solid fa-chevron-down"></i> Charger 60 de plus
                </button>
            </div>
        </div>
    </div>

    <style>
    @keyframes cpIn {
        from { opacity:0; transform:scale(.93) translateY(10px); }
        to   { opacity:1; transform:scale(1) translateY(0); }
    }
    .cv-tab {
        flex-shrink:0; padding:6px 14px; border-radius:20px; font-size:13px;
        font-weight:600; cursor:pointer; border:1.5px solid var(--border);
        background:var(--background); color:var(--text-secondary);
        white-space:nowrap; transition:all .15s;
    }
    .cv-tab:hover { border-color:var(--primary); color:var(--primary); }
    .cv-tab.active { background:var(--primary); color:#fff; border-color:var(--primary); }
    .cv-item {
        border-radius:10px; overflow:hidden; cursor:pointer;
        border:2.5px solid transparent; transition:all .15s;
        position:relative; background:var(--background);
    }
    .cv-item:hover { border-color:var(--primary); transform:scale(1.04); z-index:1; }
    .cv-item.selected { border-color:var(--primary); box-shadow:0 0 0 3px var(--primary-light); }
    .cv-item.selected::after {
        content:'✓'; position:absolute; top:4px; right:5px;
        background:var(--primary); color:#fff; border-radius:50%;
        width:18px; height:18px; font-size:10px; font-weight:700;
        display:flex; align-items:center; justify-content:center; line-height:18px; text-align:center;
    }
    .cv-photo img { width:100%; height:100%; object-fit:cover; display:block; }
    #coverTabs::-webkit-scrollbar { display:none; }
    #coverGrid::-webkit-scrollbar { width:4px; }
    #coverGrid::-webkit-scrollbar-thumb { background:var(--border); border-radius:2px; }
    </style>
    <% } %>

<!-- ── Lightbox photo de profil ─────────────────────────────────── -->
<div id="avatarLightbox" style="
    display:none; position:fixed; inset:0; z-index:9999;
    background:rgba(0,0,0,0.88); backdrop-filter:blur(6px);
    align-items:center; justify-content:center; cursor:zoom-out;
" onclick="closeLightbox()">
    <img id="avatarLightboxImg" src="" alt="" style="
        max-width:90vw; max-height:90vh; border-radius:16px;
        object-fit:contain; box-shadow:0 32px 80px rgba(0,0,0,0.6);
        animation:lbIn .22s cubic-bezier(.34,1.56,.64,1) both;
    ">
    <button onclick="closeLightbox()" style="
        position:fixed; top:20px; right:24px; background:rgba(255,255,255,0.12);
        border:none; border-radius:50%; width:44px; height:44px; cursor:pointer;
        font-size:20px; color:#fff; display:flex; align-items:center; justify-content:center;
        transition:background .2s;
    " onmouseover="this.style.background='rgba(255,255,255,0.22)'"
       onmouseout="this.style.background='rgba(255,255,255,0.12)'">
        <i class="fa-solid fa-xmark"></i>
    </button>
</div>
<style>
    @keyframes lbIn {
        from { opacity:0; transform:scale(.88); }
        to   { opacity:1; transform:scale(1); }
    }
    .profile-avatar { cursor: zoom-in; }
</style>
<script>
    function openLightbox(src) {
        const lb = document.getElementById('avatarLightbox')
        document.getElementById('avatarLightboxImg').src = src
        lb.style.display = 'flex'
        document.body.style.overflow = 'hidden'
    }
    function closeLightbox() {
        document.getElementById('avatarLightbox').style.display = 'none'
        document.body.style.overflow = ''
    }
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox() })
    document.querySelector('.profile-avatar')?.addEventListener('click', function() {
        openLightbox(this.src)
    })
</script>
</body>
</html>
