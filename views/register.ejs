<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <div class="auth-container">
        <div class="auth-visual">
            <div class="auth-visual-content">
                <i class="fa-solid fa-circle-nodes brand-icon"></i>
                <h2>Rejoins la communauté dès aujourd'hui</h2>
                <p>Crée ton profil, partage tes idées et reste connecté avec les personnes qui comptent.</p>

                <div class="auth-visual-features">
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-user-plus"></i>
                        Inscription gratuite et rapide
                    </div>
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-newspaper"></i>
                        Publie et interagis avec ton fil
                    </div>
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-shield-halved"></i>
                        Récupération de compte sécurisée
                    </div>
                </div>
            </div>
        </div>

        <div class="auth-form-side">
            <div class="auth-card">
                <div class="auth-logo">
                    <i class="fa-solid fa-circle-nodes"></i>
                    <span>SocialApp</span>
                </div>

                <h2>Créer un compte</h2>
                <p class="auth-subtitle">Rejoins la communauté dès maintenant</p>

                <% if (error && error.length > 0) { %>
                    <div class="alert alert-error">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span><%= error[0] %></span>
                    </div>
                <% } %>

                <form action="/register" method="POST">
                    <div class="form-group">
                        <label>Nom complet</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-user"></i>
                            <input type="text" name="nom" placeholder="Ton nom" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Adresse e-mail</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-envelope"></i>
                            <input type="email" name="email" placeholder="exemple@email.com" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Mot de passe</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-lock"></i>
                            <input type="password" name="motDePasse" placeholder="6 caractères minimum" required>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Confirmer le mot de passe</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-lock"></i>
                            <input type="password" name="confirmMotDePasse" placeholder="••••••••" required>
                        </div>
                    </div>

                    <!-- Séparateur sécurité -->
                    <div style="display:flex; align-items:center; gap:12px; margin:20px 0 16px;">
                        <div style="flex:1; height:1px; background:var(--border);"></div>
                        <span style="font-size:12px; color:var(--text-muted); white-space:nowrap; display:flex; align-items:center; gap:6px;">
                            <i class="fa-solid fa-shield-halved" style="color:var(--primary);"></i>
                            Sécurité du compte
                        </span>
                        <div style="flex:1; height:1px; background:var(--border);"></div>
                    </div>

                    <div class="form-group">
                        <label>Question de sécurité <span style="color:var(--text-muted); font-weight:400;">(pour récupérer ton compte)</span></label>
                        <div class="input-wrapper" style="padding:0;">
                            <i class="fa-solid fa-circle-question" style="position:absolute; left:14px; top:50%; transform:translateY(-50%); z-index:1; pointer-events:none;"></i>
                            <select name="securityQuestion" required style="padding-left:42px; appearance:none; background:transparent; border:none; width:100%; height:48px; font-size:14px; color:var(--text-primary); cursor:pointer; outline:none;">
                                <option value="" disabled selected>Choisir une question...</option>
                                <% questions.forEach(q => { %>
                                    <option value="<%= q %>"><%= q %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Ta réponse secrète</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-key"></i>
                            <input type="text" name="securityAnswer" placeholder="Ta réponse (insensible à la casse)" required autocomplete="off">
                        </div>
                        <div style="font-size:12px; color:var(--text-muted); margin-top:6px; display:flex; align-items:center; gap:5px;">
                            <i class="fa-solid fa-circle-info"></i>
                            Mémorise cette réponse — elle te permettra de retrouver l'accès à ton compte.
                        </div>
                    </div>

                    <button type="submit" class="btn">
                        <i class="fa-solid fa-user-plus"></i>
                        Créer mon compte
                    </button>
                </form>

                <div class="auth-footer">
                    Déjà un compte ? <a href="/login">Connecte-toi</a>
                </div>
            </div>
        </div>
    </div>

    <style>
        .input-wrapper select option {
            background: var(--card-bg);
            color: var(--text-primary);
        }
        .input-wrapper {
            position: relative;
        }
    </style>
</body>
</html>
