<!DOCTYPE html>
<html lang="fr">
<head><%- include('partials/head') %></head>
<body class="chat-page">
<%- include('partials/navbar', { currentPage: 'messages' }) %>

<div class="main-container chat-main-container">
  <div class="chat-page-container">

    <!-- HEADER -->
    <div class="chat-header">
      <a href="/messages" class="chat-back"><i class="fa-solid fa-arrow-left"></i></a>
      <img src="<%= otherUser.photoProfil %>" alt="" id="headerAvatar">
      <div class="chat-header-info">
        <div class="chat-header-name">
          <span><%= otherUser.nom %></span>
          <%- include('partials/badges', { badges: otherUser.badges || [] }) %>
        </div>
        <div class="chat-header-status" id="userStatus">
          <%= otherUser.enLigne ? 'En ligne' : 'Hors ligne' %>
        </div>
        <div id="typingIndicator" class="chat-header-status" style="color:var(--primary); display:none;">en train d'écrire…</div>
      </div>
      <!-- Actions header -->
      <div class="chat-header-actions">
        <button id="vaultBtn" title="Coffre-fort" class="chat-header-btn">
          <i class="fa-solid fa-lock<%- isLocked ? '' : '-open' %>"></i>
        </button>
        <button id="incognitoBtn" title="Ghost Typing" class="chat-header-btn" style="color:<%= isIncognito ? 'var(--primary)' : 'var(--text-secondary)' %>">
          <i class="fa-solid fa-ghost"></i>
        </button>
        <button id="moreOptionsBtn" title="Plus d'options" class="chat-header-btn">
          <i class="fa-solid fa-ellipsis-vertical"></i>
        </button>
      </div>
    </div>

    <!-- ============================================= -->
    <!-- MENU OPTIONS CONVERSATION                      -->
    <!-- ============================================= -->
    <div id="chatOptionsBackdrop" style="display:none;position:fixed;inset:0;z-index:1100;background:rgba(0,0,0,0.35);" onclick="closeChatOptions()"></div>
    <div id="chatOptionsPanel" style="
      display:none;
      position:fixed;
      bottom:0;left:0;right:0;
      z-index:1101;
      background:var(--surface,#fff);
      border-radius:20px 20px 0 0;
      padding:12px 0 32px;
      box-shadow:0 -4px 32px rgba(0,0,0,0.18);
      transition:transform 0.28s cubic-bezier(.4,0,.2,1);
      transform:translateY(100%);
    ">
      <!-- Poignée -->
      <div style="width:40px;height:4px;border-radius:4px;background:var(--border,#e5e7eb);margin:0 auto 16px;"></div>

      <!-- Nom affiché -->
      <div style="padding:0 20px 14px;border-bottom:1px solid var(--border,#f3f4f6);">
        <div style="font-size:11px;font-weight:600;color:var(--text-muted,#9ca3af);letter-spacing:.08em;text-transform:uppercase;margin-bottom:4px;">Conversation avec</div>
        <div id="optionsPanelName" style="font-size:16px;font-weight:700;color:var(--text-primary,#111);">
          <%= chatNickname || otherUser.nom %>
        </div>
        <% if (chatNickname) { %>
          <div style="font-size:12px;color:var(--text-muted,#9ca3af);">(<%= otherUser.nom %>)</div>
        <% } %>
      </div>

      <!-- Options -->
      <div style="padding:8px 0;">

        <!-- Pseudo -->
        <button onclick="openNicknameModal()" style="
          display:flex;align-items:center;gap:14px;
          width:100%;padding:14px 20px;
          background:none;border:none;cursor:pointer;
          text-align:left;transition:background .15s;
        " onmouseover="this.style.background='var(--hover,#f9fafb)'" onmouseout="this.style.background='none'">
          <span style="width:38px;height:38px;border-radius:12px;background:var(--primary-light,#ede9fe);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <i class="fa-solid fa-tag" style="color:var(--primary,#4f46e5);font-size:15px;"></i>
          </span>
          <div>
            <div style="font-size:15px;font-weight:600;color:var(--text-primary,#111);">Définir un pseudo</div>
            <div style="font-size:12px;color:var(--text-muted,#9ca3af);" id="currentNicknameHint">
              <%= chatNickname ? `Actuel : "${chatNickname}"` : 'Personnalise le nom affiché' %>
            </div>
          </div>
          <i class="fa-solid fa-chevron-right" style="margin-left:auto;color:var(--text-muted,#9ca3af);font-size:13px;"></i>
        </button>

        <!-- Bloquer -->
        <button id="blockBtn" onclick="toggleBlock()" style="
          display:flex;align-items:center;gap:14px;
          width:100%;padding:14px 20px;
          background:none;border:none;cursor:pointer;
          text-align:left;transition:background .15s;
        " onmouseover="this.style.background='var(--hover,#f9fafb)'" onmouseout="this.style.background='none'">
          <span id="blockIconWrap" style="width:38px;height:38px;border-radius:12px;background:<%= isBlocked ? '#fee2e2' : 'var(--surface-alt,#f3f4f6)' %>;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <i id="blockIcon" class="fa-solid <%= isBlocked ? 'fa-lock-open' : 'fa-ban' %>" style="color:<%= isBlocked ? '#ef4444' : 'var(--text-secondary,#6b7280)' %>;font-size:15px;"></i>
          </span>
          <div>
            <div id="blockLabel" style="font-size:15px;font-weight:600;color:<%= isBlocked ? '#ef4444' : 'var(--text-primary,#111)' %>;">
              <%= isBlocked ? 'Débloquer' : 'Bloquer' %>
            </div>
            <div id="blockSub" style="font-size:12px;color:var(--text-muted,#9ca3af);">
              <%= isBlocked ? 'Autoriser à nouveau les messages' : 'Ne plus recevoir ses messages' %>
            </div>
          </div>
        </button>

        <!-- Séparateur -->
        <div style="margin:4px 20px;height:1px;background:var(--border,#f3f4f6);"></div>

        <!-- Supprimer la discussion -->
        <button onclick="clearConversation()" style="
          display:flex;align-items:center;gap:14px;
          width:100%;padding:14px 20px;
          background:none;border:none;cursor:pointer;
          text-align:left;transition:background .15s;
        " onmouseover="this.style.background='#fff5f5'" onmouseout="this.style.background='none'">
          <span style="width:38px;height:38px;border-radius:12px;background:#fee2e2;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <i class="fa-solid fa-trash" style="color:#ef4444;font-size:15px;"></i>
          </span>
          <div>
            <div style="font-size:15px;font-weight:600;color:#ef4444;">Supprimer la discussion</div>
            <div style="font-size:12px;color:var(--text-muted,#9ca3af);">Effacer tous les messages</div>
          </div>
        </button>

      </div>
    </div>

    <!-- MODALE PSEUDO -->
    <div id="nicknameBackdrop" style="display:none;position:fixed;inset:0;z-index:1200;background:rgba(0,0,0,0.45);backdrop-filter:blur(2px);" onclick="closeNicknameModal()"></div>
    <div id="nicknameModal" style="
      display:none;position:fixed;
      left:50%;top:50%;transform:translate(-50%,-50%);
      z-index:1201;
      background:var(--surface,#fff);
      border-radius:18px;
      padding:24px 20px 20px;
      width:min(340px,92vw);
      box-shadow:0 8px 40px rgba(0,0,0,0.22);
    ">
      <h3 style="margin:0 0 6px;font-size:17px;font-weight:700;color:var(--text-primary,#111);">Pseudo de conversation</h3>
      <p style="margin:0 0 16px;font-size:13px;color:var(--text-muted,#9ca3af);">Visible uniquement par toi</p>
      <input id="nicknameInput" type="text" maxlength="30" placeholder="<%= otherUser.nom %>" style="
        width:100%;padding:11px 14px;
        border:1.5px solid var(--border,#e5e7eb);
        border-radius:12px;font-size:15px;
        background:var(--bg,#f9fafb);
        color:var(--text-primary,#111);
        outline:none;box-sizing:border-box;
        transition:border-color .2s;
      " onfocus="this.style.borderColor='var(--primary,#4f46e5)'" onblur="this.style.borderColor='var(--border,#e5e7eb)'">
      <div style="display:flex;gap:10px;margin-top:16px;">
        <button onclick="closeNicknameModal()" style="flex:1;padding:11px;border-radius:12px;border:1.5px solid var(--border,#e5e7eb);background:none;font-size:14px;font-weight:600;color:var(--text-secondary,#6b7280);cursor:pointer;">Annuler</button>
        <button onclick="saveNickname()" style="flex:1;padding:11px;border-radius:12px;border:none;background:var(--primary,#4f46e5);color:#fff;font-size:14px;font-weight:700;cursor:pointer;">Enregistrer</button>
      </div>
      <button onclick="clearNickname()" style="width:100%;margin-top:8px;padding:9px;border-radius:12px;border:none;background:none;font-size:13px;color:var(--text-muted,#9ca3af);cursor:pointer;">Retirer le pseudo</button>
    </div>

    <!-- VAULT OVERLAY -->
    <div id="vaultOverlay" class="vault-overlay" style="display:<%= isLocked ? 'flex' : 'none' %>;">
      <div class="vault-box">
        <i class="fa-solid fa-lock" style="font-size:48px; margin-bottom:12px; display:block;"></i>
        <h3>Conversation verrouillée</h3>
        <p>Entre ton PIN pour accéder</p>
        <input type="password" id="vaultPinInput" placeholder="PIN" maxlength="8" class="vault-pin-input">
        <button id="vaultUnlockBtn" class="btn-primary-action" style="width:100%; margin-top:12px;">Déverrouiller</button>
        <div id="vaultError" style="color:var(--error); font-size:13px; margin-top:8px; display:none;">PIN incorrect</div>
      </div>
    </div>

    <!-- MESSAGES -->
    <div class="chat-messages" id="chatMessages">
      <% messages.forEach(msg => {
        const isSent = msg.expediteur.toString() === currentUserId
        const isDeleted = msg.isDeleted
        const isBurn = msg.expiresAt
      %>
        <div class="message-wrapper-ib <%= isSent ? 'sent-wrapper' : 'received-wrapper' %>" data-id="<%= msg._id %>">
          <% if (isDeleted) { %>
            <div class="message-bubble deleted-msg <%= isSent ? 'sent' : 'received' %>">
              <span class="deleted-text"><i class="fa-solid fa-ban"></i> Ce message a été supprimé</span>
            </div>
          <% } else if (msg.audio) { %>
            <div class="message-bubble audio <%= isSent ? 'sent' : 'received' %>" data-audio="<%= msg.audio %>">
              <div class="audio-wrapper">
                <button class="play-btn"><i class="fa-solid fa-play"></i></button>
                <div class="waveform"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>
                <span class="duration"><%= msg.duration ? Math.floor(msg.duration/60)+':'+String(Math.floor(msg.duration%60)).padStart(2,'0') : '0:00' %></span>
              </div>
              <audio class="audio-player" src="<%= msg.audio %>" preload="metadata"></audio>
              <% if (isSent) { %><span class="message-status"><i class="fa-solid <%= msg.lu ? 'fa-check-double read' : 'fa-check' %>"></i></span><% } %>
            </div>
          <% } else if (msg.image) { %>
            <div class="message-bubble img-bubble <%= isSent ? 'sent' : 'received' %> <%= msg.isSticker ? 'sticker-bubble' : '' %>">
              <% if (msg.repondA && msg.repondA.contenu) { %>
                <div class="reply-quote"><i class="fa-solid fa-reply"></i> <%= msg.repondA.contenu.slice(0,50) %></div>
              <% } %>
              <div class="message-image">
                <img src="<%= msg.image %>" alt="Photo" class="<%= msg.isSticker ? 'sticker-img' : 'chat-img' %>">
                <% if (!msg.isSticker) { %>
                  <a href="<%= msg.image %>" download class="img-download-btn" title="Télécharger"><i class="fa-solid fa-download"></i></a>
                <% } %>
              </div>
              <% if (isSent) { %><span class="message-status"><i class="fa-solid <%= msg.lu ? 'fa-check-double read' : 'fa-check' %>"></i></span><% } %>
            </div>
          <% } else { %>
            <div class="message-bubble <%= isSent ? 'sent' : 'received' %> <%= isBurn ? 'burn-msg' : '' %> <%= msg.isCodeBlock ? 'code-block-msg' : '' %>" <%= isBurn ? `data-expires="${msg.expiresAt}"` : '' %>>
              <% if (msg.repondA) { %>
                <div class="reply-quote"><i class="fa-solid fa-reply"></i>
                  <% if (msg.repondA.image) { %><i class="fa-solid fa-image"></i> Image
                  <% } else { %><%= typeof msg.repondA === 'object' ? (msg.repondA.contenu || '').slice(0,50) : '' %>
                  <% } %>
                </div>
              <% } %>
              <% if (msg.isCodeBlock) { %>
                <pre class="code-content"><code><%= msg.contenu %></code></pre>
                <% if (msg.codeSignature) { %><div class="code-signature"><i class="fa-solid fa-signature"></i> <%= msg.codeSignature %></div><% } %>
              <% } else { %>
                <span class="message-text"><%- (msg.contenu || '')
                  .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
                  .replace(/\*\*([\s\S]+?)\*\*/g,'<strong>$1</strong>')
                  .replace(/\*([\s\S]+?)\*/g,'<em>$1</em>')
                  .replace(/\n/g,'<br>') %></span>
              <% } %>
              <% if (isBurn) { %><div class="burn-timer" data-expires="<%= msg.expiresAt %>"><i class="fa-regular fa-clock"></i> …</div><% } %>
              <% if (isSent) { %><span class="message-status"><i class="fa-solid <%= msg.lu ? 'fa-check-double read' : 'fa-check' %>"></i></span><% } %>
            </div>
          <% } %>
          <!-- Réactions -->
          <% if (msg.reactions && msg.reactions.length > 0) { %>
            <div class="message-reactions-ib">
              <% const gr={};msg.reactions.forEach(r=>{gr[r.emoji]=(gr[r.emoji]||0)+1}) %>
              <% Object.keys(gr).forEach(emoji=>{ %><span class="reaction-pill"><%= emoji %> <%= gr[emoji] %></span><% }) %>
            </div>
          <% } %>
          <!-- Toolbar (hover) -->
          <div class="msg-toolbar-ib">
            <% if (!isDeleted) { %>
              <button class="tb-btn reply-ib-btn" title="Répondre"><i class="fa-solid fa-reply"></i></button>
              <button class="tb-btn react-ib-btn" title="Réagir"><i class="fa-regular fa-face-smile"></i></button>
              <% if (!isSent) { %>
                <button class="tb-btn translate-ib-btn" title="Traduire"><i class="fa-solid fa-language"></i></button>
              <% } %>
              <% if (isSent) { %>
                <button class="tb-btn delete-ib-btn" title="Supprimer"><i class="fa-solid fa-trash"></i></button>
              <% } %>
            <% } %>
          </div>
          <!-- Emoji picker -->
          <div class="emoji-picker-ib">
            <span data-emoji="👍">👍</span><span data-emoji="❤️">❤️</span><span data-emoji="😂">😂</span>
            <span data-emoji="😮">😮</span><span data-emoji="😢">😢</span><span data-emoji="🔥">🔥</span>
          </div>
          <!-- Translation result -->
          <div class="translation-result" style="display:none;"></div>
        </div>
      <% }) %>
    </div>

    <!-- REPLY PREVIEW -->
    <div class="reply-preview" id="replyPreview" style="display:none;">
      <div class="reply-preview-content"><i class="fa-solid fa-reply"></i><span id="replyPreviewText"></span></div>
      <button id="cancelReply"><i class="fa-solid fa-xmark"></i></button>
    </div>

    <!-- COMMANDES IA HINT -->
    <div id="aiCommandHint" class="ai-command-hint" style="display:none;"></div>

    <!-- FORMULAIRE -->
    <form class="chat-input" id="chatForm">
      <button type="button" id="photoBtn" class="chat-icon-btn" title="Photo"><i class="fa-solid fa-image"></i></button>
      <input type="file" id="photoInput" accept="image/*" style="display:none;">
      <input type="text" id="messageInput" placeholder="Écrire un message… (/+ pour l'IA)" autocomplete="off">
      <div class="chat-action-slot">
        <button type="button" id="microBtn" class="chat-icon-btn" title="Vocal"><i class="fa-solid fa-microphone"></i></button>
        <button type="submit" id="sendBtn" class="chat-send-btn" style="display:none;"><i class="fa-solid fa-paper-plane"></i></button>
      </div>
    </form>
    <!-- BARRE ENREGISTREMENT WHATSAPP -->
    <div id="recordingBar" class="wa-recording-bar" style="display:none;">
      <button type="button" id="cancelRecordBtn" class="wa-rec-cancel"><i class="fa-solid fa-trash"></i></button>
      <div class="wa-rec-center">
        <span class="wa-rec-dot"></span>
        <span id="waTimer" class="wa-rec-timer">0:00</span>
        <div class="wa-rec-wave">
          <span></span><span></span><span></span><span></span><span></span>
          <span></span><span></span><span></span><span></span><span></span>
        </div>
      </div>
      <button type="button" id="sendRecordBtn" class="wa-rec-send"><i class="fa-solid fa-paper-plane"></i></button>
    </div>
  </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
const currentUserId = "<%= currentUserId %>";
const otherUserId = "<%= otherUser._id %>";
let isIncognito = <%= isIncognito %>;
let isLocked = <%= isLocked %>;
let replyingTo = null;
let mediaRecorder = null, audioChunks = [], isRecording = false, recordingTimer = null, recordingSeconds = 0;

let socket;
if (window.notificationSocket) { socket = window.notificationSocket; }
else { socket = io({ query: { userId: currentUserId } }); window.notificationSocket = socket; }
socket.off("new-message");
socket.off("messages-read");
socket.off("message-deleted");
socket.off("message-reacted-ib");
const chatMessages = document.getElementById("chatMessages");
const messageInput = document.getElementById("messageInput");
const sendBtn = document.getElementById("sendBtn");
const microBtn = document.getElementById("microBtn");
const replyPreview = document.getElementById("replyPreview");
const replyPreviewText = document.getElementById("replyPreviewText");
const cancelReply = document.getElementById("cancelReply");
const aiHint = document.getElementById("aiCommandHint");

// =============================================
// VAULT (COFFRE-FORT)
// =============================================
const vaultOverlay = document.getElementById("vaultOverlay");
const vaultPinInput = document.getElementById("vaultPinInput");
const vaultUnlockBtn = document.getElementById("vaultUnlockBtn");
const vaultError = document.getElementById("vaultError");
const vaultBtn = document.getElementById("vaultBtn");
const chatContent = document.getElementById("chatMessages");
const chatForm = document.getElementById("chatForm");

if (isLocked) {
  chatContent.style.filter = "blur(12px)";
  chatForm.style.display = "none";
}

vaultUnlockBtn.addEventListener("click", async () => {
  const pin = vaultPinInput.value.trim();
  if (!pin) return;
  const res = await fetch(`/api/vault/unlock/${otherUserId}`, {
    method: "POST", headers: {"Content-Type":"application/json"}, body: JSON.stringify({ pin })
  });
  const data = await res.json();
  if (data.unlocked || data.locked === false) {
    vaultOverlay.style.display = "none";
    chatContent.style.filter = "none";
    chatForm.style.display = "flex";
    isLocked = false;
  } else {
    vaultError.style.display = "block";
    setTimeout(() => { vaultError.style.display = "none"; }, 2000);
  }
});
vaultPinInput.addEventListener("keydown", e => { if (e.key === "Enter") vaultUnlockBtn.click(); });

vaultBtn.addEventListener("click", async () => {
  if (isLocked) { vaultOverlay.style.display = "flex"; return; }
  const pin = prompt("Définis un code PIN (4 chiffres min) pour verrouiller cette conversation :");
  if (!pin || pin.length < 4) { if (pin !== null) alert("PIN de 4 chiffres minimum."); return; }
  const res = await fetch(`/api/vault/lock/${otherUserId}`, {
    method: "POST", headers: {"Content-Type":"application/json"}, body: JSON.stringify({ pin })
  });
  const data = await res.json();
  if (data.success) {
    isLocked = true;
    vaultBtn.innerHTML = '<i class="fa-solid fa-lock"></i>';
    alert("Conversation verrouillée !");
  }
});

// =============================================
// INCOGNITO / GHOST TYPING
// =============================================
document.getElementById("incognitoBtn").addEventListener("click", async () => {
  isIncognito = !isIncognito;
  const btn = document.getElementById("incognitoBtn");
  btn.style.color = isIncognito ? "var(--primary)" : "var(--text-secondary)";
  await fetch("/api/settings/incognito-input", {
    method: "POST", headers: {"Content-Type":"application/json"}, body: JSON.stringify({ enabled: isIncognito })
  });
});

// =============================================
// TYPING INDICATOR
// =============================================
let typingTimeout;
messageInput.addEventListener("input", function() {
  const hasText = this.value.trim().length > 0;
  microBtn.style.display = hasText ? "none" : "flex";
  sendBtn.style.display = hasText ? "flex" : "none";

  // IA hint
  const val = this.value;
  const cmds = { "/+": '<i class="fa-solid fa-robot"></i> Demande à l\'IA', "/imagine": '<i class="fa-solid fa-wand-magic-sparkles"></i> Génère une image', "/edit": '<i class="fa-solid fa-pen"></i> Édite une image (reply requis)', "/sticker": '<i class="fa-solid fa-masks-theater"></i> Crée un sticker', "/find": '<i class="fa-solid fa-magnifying-glass"></i> Cherche dans l\'historique', "/burn": '<i class="fa-solid fa-fire"></i> Message éphémère /burn &lt;sec&gt;', "/send": '<i class="fa-solid fa-paper-plane"></i> /send @pseudo montant', "/roll": '<i class="fa-solid fa-dice"></i> Lance les dés' };
  let hint = null;
  for (const [cmd, desc] of Object.entries(cmds)) {
    if (val.startsWith(cmd)) { hint = desc; break; }
  }
  if (hint) { aiHint.innerHTML = hint; aiHint.style.display = "block"; }
  else { aiHint.style.display = "none"; }

  // Ghost typing
  if (!isIncognito) {
    socket.emit("typing", { from: currentUserId, to: otherUserId, isTyping: true });
    clearTimeout(typingTimeout);
    typingTimeout = setTimeout(() => {
      socket.emit("typing", { from: currentUserId, to: otherUserId, isTyping: false });
    }, 1500);
  }
});

socket.on("typing", (data) => {
  if (data.from !== otherUserId) return;
  const el = document.getElementById("typingIndicator");
  const status = document.getElementById("userStatus");
  if (data.isTyping) { el.style.display = "block"; status.style.display = "none"; }
  else { el.style.display = "none"; status.style.display = "block"; }
});

// =============================================
// PHOTO
// =============================================
document.getElementById("photoBtn").addEventListener("click", () => document.getElementById("photoInput").click());
document.getElementById("photoInput").addEventListener("change", async function(e) {
  const file = e.target.files[0]; if (!file) return;
  if (file.size > 5 * 1024 * 1024) { alert("Fichier trop lourd (5 Mo max)."); return; }
  const formData = new FormData();
  formData.append("image", file); formData.append("to", otherUserId);
  const res = await fetch("/messages/photo", { method: "POST", body: formData });
  const data = await res.json();
  if (!data.success) alert("Erreur: " + data.error);
  this.value = "";
});

// =============================================
// AUDIO (WhatsApp style)
// =============================================
const recordingBar = document.getElementById("recordingBar");
const waTimerEl = document.getElementById("waTimer");
let pendingAudioBlob = null, pendingAudioDuration = 0, waStream = null;

function showRecordingBar() {
  document.getElementById("chatForm").style.display = "none";
  recordingBar.style.display = "flex";
  waTimerEl.textContent = "0:00";
}
function hideRecordingBar() {
  recordingBar.style.display = "none";
  document.getElementById("chatForm").style.display = "flex";
}

microBtn.addEventListener("click", async function() {
  if (isRecording) {
    mediaRecorder.stop();
    return;
  }
  try {
    waStream = await navigator.mediaDevices.getUserMedia({ audio: true });
    mediaRecorder = new MediaRecorder(waStream, { mimeType: "audio/webm" });
    audioChunks = []; recordingSeconds = 0;
    showRecordingBar();
    recordingTimer = setInterval(() => {
      recordingSeconds++;
      const m = Math.floor(recordingSeconds/60), s = String(recordingSeconds%60).padStart(2,'0');
      waTimerEl.textContent = m+":"+s;
    }, 1000);
    mediaRecorder.ondataavailable = e => audioChunks.push(e.data);
    mediaRecorder.onstop = () => {
      clearInterval(recordingTimer);
      waStream?.getTracks().forEach(t => t.stop());
      const blob = new Blob(audioChunks, { type: "audio/webm" });
      pendingAudioBlob = blob; pendingAudioDuration = recordingSeconds;
      isRecording = false;
    };
    mediaRecorder.start(); isRecording = true;
  } catch(e) { alert("Impossible d'accéder au microphone."); }
});

document.getElementById("cancelRecordBtn").addEventListener("click", () => {
  if (mediaRecorder && isRecording) { isRecording = false; mediaRecorder.stop(); }
  clearInterval(recordingTimer);
  waStream?.getTracks().forEach(t => t.stop());
  pendingAudioBlob = null; pendingAudioDuration = 0;
  hideRecordingBar();
});

document.getElementById("sendRecordBtn").addEventListener("click", () => {
  if (mediaRecorder && isRecording) {
    mediaRecorder.onstop = () => {
      clearInterval(recordingTimer);
      waStream?.getTracks().forEach(t => t.stop());
      const blob = new Blob(audioChunks, { type: "audio/webm" });
      sendAudioMsg(blob, recordingSeconds); audioChunks = [];
      isRecording = false; pendingAudioBlob = null;
      hideRecordingBar();
    };
    mediaRecorder.stop();
  } else if (pendingAudioBlob) {
    sendAudioMsg(pendingAudioBlob, pendingAudioDuration);
    pendingAudioBlob = null; pendingAudioDuration = 0;
    hideRecordingBar();
  }
});

async function sendAudioMsg(blob, duration) {
  const fd = new FormData();
  fd.append("audio", blob, "audio.webm"); fd.append("to", otherUserId); fd.append("duration", duration);
  const res = await fetch("/messages/audio", { method: "POST", body: fd });
  const data = await res.json();
  if (!data.success) console.error(data.error);
}

// =============================================
// ENVOYER MESSAGE TEXTE
// =============================================
document.getElementById("chatForm").addEventListener("submit", async e => {
  e.preventDefault();
  const contenu = messageInput.value.trim();
  if (!contenu) return;
  messageInput.value = "";
  microBtn.style.display = "flex"; sendBtn.style.display = "none";
  aiHint.style.display = "none";
  socket.emit("typing", { from: currentUserId, to: otherUserId, isTyping: false });

  socket.emit("send-message", {
    from: currentUserId, to: otherUserId, contenu, type: "text",
    replyTo: replyingTo ? replyingTo.id : null
  });
  cancelReplyAction();
});

// =============================================
// RECEVOIR MESSAGE
// =============================================
socket.on("new-message", data => {
  const concerne = (data.expediteur === currentUserId && data.destinataire === otherUserId) ||
                   (data.expediteur === otherUserId && data.destinataire === currentUserId);
  if (!concerne) return;
  const isSent = data.expediteur === currentUserId;
  appendIbMessage(data, isSent);
  chatMessages.scrollTop = chatMessages.scrollHeight;
  if (!isSent) socket.emit("mark-read", { from: otherUserId, to: currentUserId });
});

socket.on("messages-read", data => {
  if (data.by !== otherUserId) return;
  document.querySelectorAll(".message-wrapper-ib.sent-wrapper .message-status i").forEach(i => {
    i.classList.remove("fa-check"); i.classList.add("fa-check-double","read");
  });
});

socket.on("user-status", data => {
  if (data.userId !== otherUserId) return;
  document.getElementById("userStatus").innerText = data.enLigne ? "En ligne" : "Hors ligne";
});

socket.on("message-deleted", data => {
  const wrapper = chatMessages.querySelector(`[data-id="${data.messageId}"]`);
  if (!wrapper) return;
  const bubble = wrapper.querySelector(".message-bubble");
  if (bubble) {
    bubble.className = bubble.className.replace(/\bsent\b|\breceived\b/,'') + " deleted-msg";
    bubble.innerHTML = '<span class="deleted-text"><i class="fa-solid fa-ban"></i> Ce message a été supprimé</span>';
  }
  wrapper.querySelector(".msg-toolbar-ib")?.remove();
  wrapper.querySelector(".emoji-picker-ib")?.remove();
});

socket.on("message-reacted-ib", data => {
  const wrapper = chatMessages.querySelector(`[data-id="${data.messageId}"]`);
  if (!wrapper) return;
  let reactDiv = wrapper.querySelector(".message-reactions-ib");
  if (!reactDiv) { reactDiv = document.createElement("div"); reactDiv.className = "message-reactions-ib"; wrapper.appendChild(reactDiv); }
  const grouped = {};
  data.reactions.forEach(r => { grouped[r.emoji] = (grouped[r.emoji]||0)+1; });
  reactDiv.innerHTML = Object.entries(grouped).map(([e,c]) => `<span class="reaction-pill">${e} ${c}</span>`).join("");
});

// =============================================
// TOOLBAR : REPLY, REACT, DELETE, TRANSLATE
// =============================================
chatMessages.addEventListener("click", async e => {
  // Play audio
  const playBtn = e.target.closest(".play-btn");
  if (playBtn) { playAudio(playBtn.closest(".message-bubble.audio")); return; }

  // Reply
  const replyBtn = e.target.closest(".reply-ib-btn");
  if (replyBtn) {
    const wrapper = replyBtn.closest(".message-wrapper-ib");
    const msgId = wrapper.dataset.id;
    const textEl = wrapper.querySelector(".message-text");
    const imgEl = wrapper.querySelector(".chat-img");
    const text = textEl ? textEl.innerText : (imgEl ? "[Image]" : "");
    replyingTo = { id: msgId, text };
    replyPreviewText.innerText = text.slice(0,60) + (text.length > 60 ? "…" : "");
    replyPreview.style.display = "flex";
    messageInput.focus();
    return;
  }

  // React
  const reactBtn = e.target.closest(".react-ib-btn");
  if (reactBtn) {
    const wrapper = reactBtn.closest(".message-wrapper-ib");
    document.querySelectorAll(".emoji-picker-ib.active").forEach(p => p.classList.remove("active"));
    wrapper.querySelector(".emoji-picker-ib")?.classList.toggle("active");
    return;
  }

  // Emoji picked
  const emojiSpan = e.target.closest(".emoji-picker-ib span");
  if (emojiSpan) {
    const wrapper = emojiSpan.closest(".message-wrapper-ib");
    const msgId = wrapper.dataset.id;
    const emoji = emojiSpan.dataset.emoji;
    await fetch(`/api/messages/${msgId}/react`, {
      method: "POST", headers: {"Content-Type":"application/json"}, body: JSON.stringify({ emoji })
    });
    wrapper.querySelector(".emoji-picker-ib")?.classList.remove("active");
    return;
  }

  // Delete
  const deleteBtn = e.target.closest(".delete-ib-btn");
  if (deleteBtn) {
    if (!confirm("Supprimer ce message ?")) return;
    const wrapper = deleteBtn.closest(".message-wrapper-ib");
    const msgId = wrapper.dataset.id;
    await fetch(`/api/messages/${msgId}/delete`, { method: "POST" });
    return;
  }

  // Translate
  const translateBtn = e.target.closest(".translate-ib-btn");
  if (translateBtn) {
    const wrapper = translateBtn.closest(".message-wrapper-ib");
    const textEl = wrapper.querySelector(".message-text");
    if (!textEl) return;
    const transDiv = wrapper.querySelector(".translation-result");
    if (transDiv.style.display === "block") { transDiv.style.display = "none"; return; }
    transDiv.textContent = "Traduction en cours…"; transDiv.style.display = "block";
    const res = await fetch("/api/ai/translate", {
      method: "POST", headers: {"Content-Type":"application/json"}, body: JSON.stringify({ text: textEl.innerText })
    });
    const data = await res.json();
    transDiv.textContent = data.translation || data.error || "Erreur";
    return;
  }

  // Close pickers
  if (!e.target.closest(".emoji-picker-ib") && !e.target.closest(".react-ib-btn")) {
    document.querySelectorAll(".emoji-picker-ib.active").forEach(p => p.classList.remove("active"));
  }
});

cancelReply.addEventListener("click", cancelReplyAction);
function cancelReplyAction() { replyingTo = null; replyPreview.style.display = "none"; }

// =============================================
// APPEND MESSAGE
// =============================================
function appendIbMessage(data, isSent) {
  const wrapper = document.createElement("div");
  wrapper.className = `message-wrapper-ib ${isSent ? "sent-wrapper" : "received-wrapper"}`;
  wrapper.dataset.id = data._id;
  let html = "";

  if (data.audio) {
    let dur = "0:00";
    if (data.duration) { const m=Math.floor(data.duration/60),s=String(Math.floor(data.duration%60)).padStart(2,'0'); dur=m+":"+s; }
    html = `<div class="message-bubble audio ${isSent?"sent":"received"}" data-audio="${data.audio}">
      <div class="audio-wrapper">
        <button class="play-btn"><i class="fa-solid fa-play"></i></button>
        <div class="waveform"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>
        <span class="duration">${dur}</span>
      </div>
      <audio class="audio-player" src="${data.audio}" preload="metadata"></audio>
      ${isSent?'<span class="message-status"><i class="fa-solid fa-check"></i></span>':""}
    </div>`;
  } else if (data.image) {
    const isSticker = data.isSticker;
    html = `<div class="message-bubble img-bubble ${isSent?"sent":"received"} ${isSticker?"sticker-bubble":""}">
      <div class="message-image">
        <img src="${data.image}" alt="Photo" class="${isSticker?"sticker-img":"chat-img"}">
        ${!isSticker?`<a href="${data.image}" download class="img-download-btn" title="Télécharger"><i class="fa-solid fa-download"></i></a>`:""}
      </div>
      ${isSent?'<span class="message-status"><i class="fa-solid fa-check"></i></span>':""}
    </div>`;
  } else {
    const isBurn = data.expiresAt;
    let replyHtml = "";
    if (data.repondA) {
      const rc = typeof data.repondA === "object" ? (data.repondA.image ? "[Image]" : (data.repondA.contenu||"").slice(0,50)) : "";
      replyHtml = `<div class="reply-quote"><i class="fa-solid fa-reply"></i> ${esc(rc)}</div>`;
    }
    html = `<div class="message-bubble ${isSent?"sent":"received"} ${isBurn?"burn-msg":""}">
      ${replyHtml}
      <span class="message-text">${renderMarkdown(data.contenu||"")}</span>
      ${isBurn?`<div class="burn-timer" data-expires="${data.expiresAt}"><i class="fa-regular fa-clock"></i> …</div>`:""}
      ${isSent?'<span class="message-status"><i class="fa-solid fa-check"></i></span>':""}
    </div>`;
  }

  html += `<div class="msg-toolbar-ib">
    <button class="tb-btn reply-ib-btn" title="Répondre"><i class="fa-solid fa-reply"></i></button>
    <button class="tb-btn react-ib-btn" title="Réagir"><i class="fa-regular fa-face-smile"></i></button>
    ${!isSent?'<button class="tb-btn translate-ib-btn" title="Traduire"><i class="fa-solid fa-language"></i></button>':""}
    ${isSent?'<button class="tb-btn delete-ib-btn" title="Supprimer"><i class="fa-solid fa-trash"></i></button>':""}
  </div>
  <div class="emoji-picker-ib"><span data-emoji="👍">👍</span><span data-emoji="❤️">❤️</span><span data-emoji="😂">😂</span><span data-emoji="😮">😮</span><span data-emoji="😢">😢</span><span data-emoji="🔥">🔥</span></div>
  <div class="message-reactions-ib"></div>
  <div class="translation-result" style="display:none;"></div>`;

  wrapper.innerHTML = html;
  chatMessages.appendChild(wrapper);

  // Burn timer
  if (data.expiresAt) startBurnTimer(wrapper.querySelector(".burn-timer"), data.expiresAt);
}

// =============================================
// BURN TIMER
// =============================================
function startBurnTimer(el, expiresAt) {
  if (!el) return;
  const interval = setInterval(() => {
    const remaining = Math.max(0, Math.floor((new Date(expiresAt) - Date.now()) / 1000));
    el.innerHTML = `<i class="fa-solid fa-fire"></i> ${remaining}s`;
    if (remaining <= 0) clearInterval(interval);
  }, 1000);
}
// Init existing burn timers
document.querySelectorAll(".burn-timer").forEach(el => {
  const expires = el.dataset.expires;
  if (expires) startBurnTimer(el, expires);
});

// =============================================
// AUDIO PLAYER
// =============================================
function playAudio(element) {
  if (!element) return;
  const player = element.querySelector(".audio-player");
  const btn = element.querySelector(".play-btn i");
  if (!player) return;
  if (player.paused) {
    document.querySelectorAll(".audio-player").forEach(a => { if (a!==player){a.pause();a.currentTime=0;const p=a.closest(".message-bubble.audio");if(p){p.classList.remove("playing");const b=p.querySelector(".play-btn i");if(b)b.className="fa-solid fa-play";}} });
    player.play(); element.classList.add("playing"); if(btn)btn.className="fa-solid fa-pause";
  } else { player.pause(); element.classList.remove("playing"); if(btn)btn.className="fa-solid fa-play"; }
  player.onended = () => { element.classList.remove("playing"); if(btn)btn.className="fa-solid fa-play"; };
}
document.querySelectorAll(".message-bubble.audio .audio-player").forEach(a => {
  a.onloadedmetadata = function() {
    const el = a.closest(".message-bubble.audio")?.querySelector(".duration");
    if (el && a.duration && !isNaN(a.duration)) { const m=Math.floor(a.duration/60),s=String(Math.floor(a.duration%60)).padStart(2,'0'); el.textContent=m+":"+s; }
  };
});

function esc(str) { const d=document.createElement("div"); d.innerText=str||""; return d.innerHTML; }
function renderMarkdown(str) {
  return esc(str)
    .replace(/\*\*([\s\S]+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*([\s\S]+?)\*/g, '<em>$1</em>')
    .replace(/\n/g, '<br>');
}

socket.emit("mark-read", { from: otherUserId, to: currentUserId });
chatMessages.scrollTop = chatMessages.scrollHeight;

// =============================================
// MENU OPTIONS CONVERSATION
// =============================================
let isBlockedState = <%= isBlocked %>;
const chatOptionsPanel = document.getElementById("chatOptionsPanel");
const chatOptionsBackdrop = document.getElementById("chatOptionsBackdrop");

document.getElementById("moreOptionsBtn").addEventListener("click", () => {
  chatOptionsPanel.style.display = "block";
  chatOptionsBackdrop.style.display = "block";
  requestAnimationFrame(() => { chatOptionsPanel.style.transform = "translateY(0)"; });
});

function closeChatOptions() {
  chatOptionsPanel.style.transform = "translateY(100%)";
  setTimeout(() => {
    chatOptionsPanel.style.display = "none";
    chatOptionsBackdrop.style.display = "none";
  }, 280);
}

async function toggleBlock() {
  const res = await fetch(`/api/chat/${otherUserId}/block`, { method: "POST" });
  const data = await res.json();
  if (!data.success) return;
  isBlockedState = data.blocked;
  const icon = document.getElementById("blockIcon");
  const label = document.getElementById("blockLabel");
  const sub = document.getElementById("blockSub");
  const wrap = document.getElementById("blockIconWrap");
  if (isBlockedState) {
    icon.className = "fa-solid fa-lock-open";
    icon.style.color = "#ef4444";
    wrap.style.background = "#fee2e2";
    label.textContent = "Débloquer";
    label.style.color = "#ef4444";
    sub.textContent = "Autoriser à nouveau les messages";
  } else {
    icon.className = "fa-solid fa-ban";
    icon.style.color = "var(--text-secondary,#6b7280)";
    wrap.style.background = "var(--surface-alt,#f3f4f6)";
    label.textContent = "Bloquer";
    label.style.color = "var(--text-primary,#111)";
    sub.textContent = "Ne plus recevoir ses messages";
  }
  closeChatOptions();
  const msg = isBlockedState ? "Utilisateur bloqué." : "Utilisateur débloqué.";
  showToast(msg, isBlockedState ? "error" : "success");
}

function openNicknameModal() {
  closeChatOptions();
  const input = document.getElementById("nicknameInput");
  input.value = "<%= chatNickname || '' %>";
  document.getElementById("nicknameBackdrop").style.display = "block";
  document.getElementById("nicknameModal").style.display = "block";
  setTimeout(() => input.focus(), 80);
}
function closeNicknameModal() {
  document.getElementById("nicknameBackdrop").style.display = "none";
  document.getElementById("nicknameModal").style.display = "none";
}

async function saveNickname() {
  const val = document.getElementById("nicknameInput").value.trim();
  const res = await fetch(`/api/chat/${otherUserId}/nickname`, {
    method: "POST", headers: {"Content-Type":"application/json"}, body: JSON.stringify({ nickname: val })
  });
  const data = await res.json();
  if (!data.success) return;
  closeNicknameModal();
  const displayName = val || "<%= otherUser.nom %>";
  document.getElementById("optionsPanelName").textContent = displayName;
  document.querySelector(".chat-header > div:nth-child(3) > div:first-child").textContent = displayName;
  document.getElementById("currentNicknameHint").textContent = val ? `Actuel : "${val}"` : "Personnalise le nom affiché";
  showToast(val ? `Pseudo défini : "${val}"` : "Pseudo retiré", "success");
}

async function clearNickname() {
  document.getElementById("nicknameInput").value = "";
  await saveNickname();
}

async function clearConversation() {
  closeChatOptions();
  if (!confirm("Supprimer toute la discussion ? Cette action est irréversible.")) return;
  const res = await fetch(`/api/chat/${otherUserId}/clear`, { method: "POST" });
  const data = await res.json();
  if (data.success) {
    document.getElementById("chatMessages").innerHTML = "";
    showToast("Discussion supprimée.", "success");
  }
}

function showToast(msg, type) {
  const t = document.createElement("div");
  t.textContent = msg;
  t.style.cssText = `
    position:fixed;bottom:80px;left:50%;transform:translateX(-50%);
    background:${type==="error"?"#ef4444":"#22c55e"};color:#fff;
    padding:10px 20px;border-radius:12px;font-size:14px;font-weight:600;
    z-index:9999;box-shadow:0 4px 16px rgba(0,0,0,0.18);
    animation:fadeIn .2s ease;
  `;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 2800);
}

// Filigrane anti-capture (messages privés)
(()=>{
  const wm=document.createElement("div");
  wm.style.cssText="position:fixed;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:9997;overflow:hidden;opacity:0.026;user-select:none;display:flex;flex-direction:column;justify-content:space-around;";
  const uid="<%= currentUserId %>";
  const txt=Array(6).fill(`SocialApp Confidentiel ${uid}`).join("   ");
  for(let i=0;i<18;i++){
    const row=document.createElement("div");
    row.textContent=txt;
    row.style.cssText=`white-space:nowrap;font-size:12px;transform:rotate(-18deg) translateX(-${10+(i%4)*8}%);color:var(--text-primary);letter-spacing:3px;`;
    wm.appendChild(row);
  }
  document.body.appendChild(wm);
})();
</script>
</body>
</html>
