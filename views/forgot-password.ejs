<!DOCTYPE html>
<html lang="fr">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <div class="auth-container">
        <div class="auth-visual">
            <div class="auth-visual-content">
                <i class="fa-solid fa-key brand-icon"></i>
                <h2>Mot de passe oublié ?</h2>
                <p>Entre ton adresse email pour retrouver l'accès à ton compte via ta question secrète ou un code de récupération.</p>
                <div class="auth-visual-features">
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>Vérification par question secrète</span>
                    </div>
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-key"></i>
                        <span>Ou utilise un code de récupération</span>
                    </div>
                    <div class="auth-visual-feature">
                        <i class="fa-solid fa-envelope-open-text" style="opacity:0.4;"></i>
                        <span style="opacity:0.5;">Aucun email nécessaire</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="auth-form-side">
            <div class="auth-card">
                <div class="auth-logo">
                    <i class="fa-solid fa-circle-nodes"></i>
                    <span>SocialApp</span>
                </div>

                <h2>Mot de passe oublié</h2>
                <p class="auth-subtitle">Retrouve l'accès à ton compte</p>

                <% if (error && error.length > 0) { %>
                    <div class="alert alert-error">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        <span><%= error[0] %></span>
                    </div>
                <% } %>

                <% if (success && success.length > 0) { %>
                    <div class="alert alert-success">
                        <i class="fa-solid fa-circle-check"></i>
                        <span><%= success[0] %></span>
                    </div>
                <% } %>

                <form action="/forgot-password" method="POST">
                    <div class="form-group">
                        <label>Adresse e-mail du compte</label>
                        <div class="input-wrapper">
                            <i class="fa-solid fa-envelope"></i>
                            <input type="email" name="email" placeholder="exemple@email.com" required autofocus>
                        </div>
                    </div>

                    <button type="submit" class="btn">
                        <i class="fa-solid fa-arrow-right"></i>
                        Continuer
                    </button>
                </form>

                <div class="auth-footer">
                    <a href="/login">Retour à la connexion</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
