<!-- ========== BULLES DE STORIES ========== -->
<div class="card" style="padding:16px 20px;">
    <div class="stories-container" id="stories-bubbles">
        <!-- Chargé dynamiquement par stories.js -->
        <div class="story-bubble">
            <div class="story-add-btn" onclick="openStoryCreator()">
                <i class="fa-solid fa-plus"></i>
            </div>
            <div class="story-label">Ta story</div>
        </div>
    </div>
</div>

<!-- ========== VISIONNEUSE DE STORY ========== -->
<div class="story-viewer-overlay" id="story-viewer-overlay">

    <!-- Barre de progression -->
    <div class="story-progress-bar" id="story-progress-container"></div>

    <!-- Header -->
    <div class="story-viewer-header">
        <img src="" alt="" id="story-author-avatar">
        <div>
            <div class="story-author-name" id="story-author-name" style="font-size:14px; font-weight:700; color:#fff;"></div>
            <div id="story-time" style="font-size:12px; color:rgba(255,255,255,0.7);"></div>
        </div>
        <button class="story-viewer-close" onclick="closeStoryViewer()">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>

    <!-- Média -->
    <div class="story-viewer-media">
        <div id="story-media-container" style="width:100%; height:100%; display:flex; align-items:center; justify-content:center;"></div>
        <div class="story-viewer-text-overlay" id="story-text-overlay"></div>

        <!-- Navigation tactile -->
        <div class="story-viewer-nav-prev" onclick="goToPrevStory()"></div>
        <div class="story-viewer-nav-next" onclick="goToNextStory()"></div>
    </div>

    <!-- Footer -->
    <div class="story-viewer-footer" style="z-index:20;">
        <div class="story-views-count" onclick="showViewersPanel()" style="cursor:pointer; padding:6px 10px; border-radius:20px; background:rgba(255,255,255,0.15);">
            <i class="fa-solid fa-eye" style="font-size:12px;"></i>
            <span id="story-views-count">0</span>
            <i class="fa-solid fa-chevron-up" style="font-size:10px; margin-left:2px;"></i>
        </div>
        <div class="story-emoji-reactions" style="position:relative; z-index:20;">
            <button class="story-emoji-btn" onclick="event.stopPropagation(); reactToStory('❤️')">❤️</button>
            <button class="story-emoji-btn" onclick="event.stopPropagation(); reactToStory('😂')">😂</button>
            <button class="story-emoji-btn" onclick="event.stopPropagation(); reactToStory('😮')">😮</button>
            <button class="story-emoji-btn" onclick="event.stopPropagation(); reactToStory('🔥')">🔥</button>
            <button class="story-emoji-btn" onclick="event.stopPropagation(); reactToStory('👏')">👏</button>
        </div>
    </div>
</div>

<!-- ========== PANEL : QUI A VU ========== -->
<div id="story-viewers-backdrop" onclick="closeViewersPanel()" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:999998;"></div>
<div id="story-viewers-panel" style="display:none; position:fixed; bottom:0; left:0; right:0; background:var(--card-bg); border-radius:18px 18px 0 0; z-index:999999; padding:20px 20px 32px; max-height:55vh; overflow-y:auto; box-shadow:0 -6px 32px rgba(0,0,0,0.35);">
    <div style="width:36px; height:4px; background:var(--border); border-radius:4px; margin:0 auto 18px;"></div>
    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
        <div style="font-weight:700; font-size:15px; color:var(--text-primary);">
            <i class="fa-solid fa-eye" style="color:var(--primary); margin-right:6px;"></i>Vues
        </div>
        <button onclick="closeViewersPanel()" style="background:none; border:none; cursor:pointer; color:var(--text-muted); font-size:20px; padding:4px;">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>
    <div id="story-viewers-list"></div>
</div>

<!-- ========== CRÉATEUR DE STORY ========== -->
<div class="story-creator-overlay" id="story-creator-overlay">
    <div class="story-creator-card">

        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:16px;">
            <h3 style="font-size:16px; font-weight:700; color:var(--text-primary);">
                <i class="fa-solid fa-circle-plus" style="color:var(--primary);"></i>
                Créer une story
            </h3>
            <button onclick="closeStoryCreator()" style="background:none; border:none; cursor:pointer; color:var(--text-muted); font-size:18px;">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <!-- Aperçu -->
        <div class="story-creator-preview" id="story-preview-area" style="background:#4f46e5; cursor:pointer;" onclick="document.getElementById('story-file-input').click()">
            <div style="text-align:center; color:rgba(255,255,255,0.7);">
                <i class="fa-solid fa-image" style="font-size:32px; margin-bottom:8px; display:block;"></i>
                <div style="font-size:13px;">Clique pour ajouter une photo ou vidéo</div>
            </div>
        </div>
        <input type="file" id="story-file-input" accept="image/*,video/*" style="display:none" onchange="handleStoryFileSelect(event)" capture="environment">

        <!-- Couleurs de fond -->
        <div style="font-size:12px; font-weight:600; color:var(--text-secondary); margin-bottom:8px; margin-top:4px;">
            Couleur de fond (pour story texte)
        </div>
        <div class="story-color-picker" id="story-color-picker"></div>

        <!-- Texte -->
        <div class="form-group" style="margin-bottom:14px;">
            <div class="input-wrapper">
                <i class="fa-solid fa-pen"></i>
                <input type="text" id="story-text-input" placeholder="Ajouter un texte (optionnel)" maxlength="200">
            </div>
        </div>

        <!-- Boutons -->
        <div style="display:flex; gap:10px;">
            <button onclick="closeStoryCreator()" class="btn btn-secondary">
                Annuler
            </button>
            <button onclick="publishStory()" class="btn" id="story-publish-btn">
                <i class="fa-solid fa-paper-plane"></i> Publier
            </button>
        </div>
    </div>
</div>
